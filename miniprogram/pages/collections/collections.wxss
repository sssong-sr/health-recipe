/* pages/collections/collections.wxss */

.container {
  background: #FAFAFA;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #FFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
}

.page-count {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 列表 */
.recipes-section {
  padding: 16rpx;
}

.recipes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.recipe-card {
  background: #FFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.recipe-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  background: #F5F5F5;
}

.recipe-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.recipe-cal-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(7, 193, 96, 0.9);
  color: #FFF;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.cal-value {
  font-weight: 600;
  font-size: 20rpx;
}

.cal-unit {
  font-size: 16rpx;
  opacity: 0.9;
}

.recipe-info {
  padding: 12rpx;
}

.recipe-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recipe-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.recipe-tags {
  display: flex;
  gap: 6rpx;
}

.tag {
  display: inline-block;
  background: #F5F5F5;
  color: #666;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
}

/* 卡片操作 */
.card-actions {
  padding: 8rpx 12rpx 12rpx;
}

.btn-uncollect {
  width: 100%;
  background: #FFF;
  border: 1rpx solid #FF4D4F;
  color: #FF4D4F;
  font-size: 20rpx;
  padding: 6rpx 0;
  border-radius: 6rpx;
  line-height: 1.2;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC;
  margin-bottom: 32rpx;
}

.btn-go-recipes {
  background: #07C160;
  color: #FFF;
  font-size: 26rpx;
  padding: 16rpx 48rpx;
  border-radius: 44rpx;
}
