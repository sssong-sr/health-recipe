/* pages/recipe-detail/recipe-detail.wxss */

.container {
  background: #FAFAFA;
  padding-bottom: 120rpx;
}

/* 菜谱头部 */
.recipe-header {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #F5F5F5;
}

.recipe-image {
  width: 100%;
  height: 100%;
}

.recipe-overlay {
  position: absolute;
  bottom: 0;
  right: 0;
  left: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.3), transparent);
  padding: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.recipe-cal-large {
  background: rgba(7, 193, 96, 0.9);
  color: #FFF;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cal-num {
  font-size: 32rpx;
  font-weight: 700;
}

.cal-unit {
  font-size: 18rpx;
  opacity: 0.9;
}

/* 菜谱基本信息 */
.recipe-info-card {
  margin: 16rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

.recipe-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.recipe-meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
}

.meta-icon {
  font-size: 32rpx;
}

.meta-label {
  font-size: 20rpx;
  color: #999;
}

.meta-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

/* 可折叠区域 */
.section {
  margin: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  cursor: pointer;
  user-select: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-toggle {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.2s;
}

.section-content {
  padding: 0 16rpx 16rpx 16rpx;
}

/* 食材清单 */
.ingredient-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-checkbox {
  margin-right: 12rpx;
}

.checkbox {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #DDD;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.checkbox.checked::after {
  content: '✓';
  color: #FFF;
  font-size: 16rpx;
  font-weight: 600;
}

.ingredient-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ingredient-name {
  font-size: 26rpx;
  color: #333;
}

.ingredient-amount {
  font-size: 22rpx;
  color: #999;
}

/* 烹饪步骤 */
.step-item {
  display: flex;
  margin-bottom: 20rpx;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: #07C160;
  color: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-description {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.step-image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

/* 营养信息 */
.nutrition-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nutrition-bar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nutrition-bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #333;
}

.nutrition-bar-value {
  font-weight: 600;
  color: #07C160;
}

.nutrition-bar-track {
  width: 100%;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.nutrition-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.nutrition-bar-fill.protein {
  background: #FF6B6B;
}

.nutrition-bar-fill.carbs {
  background: #4ECDC4;
}

.nutrition-bar-fill.fat {
  background: #FFE66D;
}

.nutrition-bar-fill.fiber {
  background: #95E1D3;
}

/* 标签 */
.tags-section {
  margin: 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  background: #F5F5F5;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 底部操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: #FFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  flex: 1;
  background: #07C160;
  color: #FFF;
  border-radius: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-secondary {
  flex: 1;
  background: #F5F5F5;
  color: #666;
  border-radius: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

/* 跳转到菜单 */
.menu-link {
  padding: 12rpx 16rpx 120rpx;
}

.btn-menu-link {
  width: 100%;
  background: #FFF;
  border: 2rpx solid #07C160;
  color: #07C160;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 44rpx;
}
