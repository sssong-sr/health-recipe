/* pages/profile/profile.wxss */

.achievements {
  background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
}

.achievements .title {
  color: #FFF;
}

.achievements-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.achievement-item {
  text-align: center;
}

.achievement-item .num {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFF;
}

.achievement-item .num.highlight {
  font-size: 56rpx;
}

.achievement-item .label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.badges {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.3);
}

.badge {
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.3);
  color: #FFF;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 鼓励 */
.encouragement {
  background: #FFF0F0;
  text-align: center;
}

.encouragement .msg {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item .label {
  font-size: 28rpx;
  color: #333;
}

.setting-item .value {
  color: #07C160;
  font-size: 28rpx;
}

/* 打卡 */
.checkin-section {
  margin-top: 40rpx;
}

.btn-checkin {
  background: #07C160;
  color: #FFF;
  border-radius: 44rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-checkin.checked {
  background: #CCC;
}

.btn-checkin[disabled] {
  background: #CCC;
}

/* 提示 */
.tip-card {
  margin-top: 40rpx;
  padding: 24rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
  text-align: center;
}

.tip-card text {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
