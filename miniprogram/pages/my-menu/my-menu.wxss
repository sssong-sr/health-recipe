/* pages/my-menu/my-menu.wxss */

.container {
  background: #FAFAFA;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #FFF;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
}

.stats-date {
  font-size: 24rpx;
  opacity: 0.9;
}

.stats-content {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 16rpx;
}

/* 热量进度 */
.stats-item {
  margin-bottom: 16rpx;
}

.stats-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.stats-value {
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #FFF;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-fill.over {
  background: #FFD700;
}

.stats-tip {
  display: block;
  font-size: 22rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

/* 营养信息 */
.nutrition-section {
  margin-top: 16rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 8rpx;
  border-radius: 8rpx;
}

.nutrition-icon {
  font-size: 28rpx;
}

.nutrition-label {
  font-size: 20rpx;
  opacity: 0.9;
}

.nutrition-value {
  font-size: 24rpx;
  font-weight: 600;
}

/* 菜谱列表 */
.menu-section {
  padding: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 0;
  overflow: hidden;
}

.menu-item-info {
  display: flex;
  flex: 1;
  align-items: center;
  padding: 12rpx;
}

.menu-item-image {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.menu-item-content {
  flex: 1;
  margin-left: 12rpx;
}

.menu-item-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.menu-item-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.menu-item-tags {
  display: flex;
  gap: 6rpx;
}

.tag-small {
  background: #F5F5F5;
  color: #666;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
}

.menu-item-cal {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 12rpx;
  padding: 8rpx;
  background: #E8F7EA;
  border-radius: 8rpx;
}

.cal-number {
  font-size: 24rpx;
  font-weight: 600;
  color: #07C160;
}

.cal-unit {
  font-size: 18rpx;
  color: #07C160;
}

.btn-remove {
  background: #FFF;
  border: 1rpx solid #FF4D4F;
  color: #FF4D4F;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  margin: 12rpx;
  border-radius: 8rpx;
}

/* 操作按钮 */
.actions-section {
  margin-top: 20rpx;
}

.btn-clear {
  width: 100%;
  background: #FFF;
  border: 2rpx solid #FF4D4F;
  color: #FF4D4F;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 44rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC;
  margin-bottom: 32rpx;
}

.btn-go-recipes {
  background: #07C160;
  color: #FFF;
  font-size: 26rpx;
  padding: 16rpx 48rpx;
  border-radius: 44rpx;
}
