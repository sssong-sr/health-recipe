/* pages/ai-chat/ai-chat.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
}

/* 授权弹窗 */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.auth-content {
  width: 560rpx;
  background: #FFF;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.auth-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160;
  color: #FFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.auth-btn::after {
  border: none;
}

.auth-skip {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 220rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row;
  justify-content: flex-end;
}

.message-item.assistant {
  flex-direction: row;
  justify-content: flex-start;
}

/* 头像 - 统一小尺寸 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-size: 32rpx;
}

.user-avatar {
  background: #E8E8E8;
  margin-left: 12rpx;
  width: 64rpx;
  height: 64rpx;
}

.user-avatar .avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 28rpx;
}

.message-content {
  max-width: 70%;
  margin: 0 12rpx;
}

/* 消息气泡 */
.message-bubble {
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  line-height: 1.6;
  font-size: 28rpx;
  word-break: break-all;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  background: #07C160;
  color: #FFF;
  border-bottom-right-radius: 4rpx;
}

.ai-bubble {
  background: #FFF;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

.loading-bubble {
  background: #FFF;
  padding: 20rpx 32rpx;
}

.loading-dots {
  display: flex;
  gap: 6rpx;
}

.loading-dots text {
  animation: bounce 1.4s infinite ease-in-out;
  font-size: 28rpx;
  color: #666;
}

.loading-dots text:nth-child(1) { animation-delay: 0s; }
.loading-dots text:nth-child(2) { animation-delay: 0.2s; }
.loading-dots text:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-8rpx); }
}

/* 快捷问题 */
.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.quick-q {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFF;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFF;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.input-wrapper {
  display: flex;
  margin-bottom: 12rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.input-actions {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  background: #F5F5F5;
  color: #666;
  font-size: 26rpx;
  border-radius: 30rpx;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}
