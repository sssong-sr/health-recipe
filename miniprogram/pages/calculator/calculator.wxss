/* pages/calculator/calculator.wxss */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.goal-options {
  display: flex;
  gap: 20rpx;
}

.goal-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.goal-item.active {
  background: #07C160;
  color: #FFF;
}

.form-row {
  margin-bottom: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
}

.form-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.form-unit {
  width: 60rpx;
  font-size: 28rpx;
  color: #999;
  text-align: right;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-item {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.gender-item.active {
  background: #07C160;
  color: #FFF;
}

.exercise-slider {
  padding: 0 10rpx;
}

.exercise-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.exercise-labels text {
  font-size: 22rpx;
  color: #999;
}

.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160;
  color: #FFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}
