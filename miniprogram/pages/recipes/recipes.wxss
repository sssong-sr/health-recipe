/* pages/recipes/recipes.wxss */

.container {
  background: #FAFAFA;
  padding-bottom: 20rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #FFF;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.welcome {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.welcome-icon {
  font-size: 50rpx;
}

.welcome-text .title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.welcome-text .subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.target-info {
  display: flex;
  gap: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.target-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.target-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.target-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 筛选区域 */
.filter-section {
  padding: 20rpx;
}

.filter-group {
  margin-bottom: 20rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag {
  padding: 10rpx 20rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #999;
  transition: all 0.2s;
}

.filter-tag.active {
  background: #07C160;
  color: #FFF;
}

/* 搜索框 */
.search-box {
  position: relative;
  margin-top: 16rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 20rpx 0 40rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #999;
}

/* 菜谱列表 */
.recipes-section {
  padding: 16rpx;
}

.recipes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.recipe-card {
  background: #FFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.recipe-card:active {
  transform: scale(0.98);
}

.recipe-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 */
  background: #F5F5F5;
  overflow: hidden;
}

.recipe-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 热量徽章 */
.recipe-cal-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(7, 193, 96, 0.9);
  color: #FFF;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 18rpx;
}

.cal-value {
  font-weight: 600;
  font-size: 20rpx;
}

.cal-unit {
  font-size: 16rpx;
  opacity: 0.9;
}

/* 已选标记 */
.recipe-selected-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.4);
}

/* 菜谱信息 */
.recipe-info {
  padding: 12rpx;
}

.recipe-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recipe-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.recipe-tags {
  display: flex;
  gap: 6rpx;
}

.tag {
  display: inline-block;
  background: #F5F5F5;
  color: #666;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
}

/* 卡片操作按钮 */
.card-btns {
  display: flex;
  gap: 8rpx;
  padding: 0 12rpx 12rpx;
}

.btn-card {
  flex: 1;
  font-size: 22rpx;
  padding: 8rpx 0;
  border-radius: 8rpx;
  line-height: 1.4;
}

.btn-add {
  background: #07C160;
  color: #FFF;
}

.btn-added {
  background: #E8F7EA;
  color: #07C160;
}

.btn-collect {
  background: #F5F5F5;
  color: #999;
  max-width: 80rpx;
}

.btn-collected {
  background: #FFF0F0;
  color: #FF4D4F;
  max-width: 80rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC;
}

/* 底部菜单统计 */
.menu-stats-section {
  margin: 16rpx;
  margin-bottom: 30rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.stats-count {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
}

.stats-content {
  margin-bottom: 16rpx;
}

/* 热量进度 */
.stats-item {
  margin-bottom: 16rpx;
}

.stats-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stats-value {
  color: #07C160;
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160 0%, #06AD56 100%);
  transition: width 0.3s;
}

/* 营养信息 */
.nutrition-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  padding: 12rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999;
}

.nutrition-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

/* 操作按钮 */
.stats-actions {
  display: flex;
  gap: 12rpx;
}

.btn-primary {
  flex: 1;
  background: #07C160;
  color: #FFF;
  border-radius: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-secondary {
  flex: 1;
  background: #F5F5F5;
  color: #666;
  border-radius: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}
